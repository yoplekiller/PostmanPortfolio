  "item": [
    {
      "name": "Get Popular Movies",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Satus is 200\", function(){\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Results array exists\", function(){\r",
              "    pm.expect(jsonData).to.have.property(\"results\");\r",
              "    pm.expect(jsonData.results).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Results is not empty\", function () {\r",
              "    pm.expect(jsonData.results.length).to.be.above(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
