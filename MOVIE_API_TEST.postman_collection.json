    {
      "name": "Search Movie",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Status is 200\", function(){\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Results array exists\", function(){\r",
              "    pm.expect(jsonData).to.have.property(\"results\");\r",
              "});\r",
              "\r",
              "pm.test(\"Search result contains keyword\", function () {\r",
              "    pm.expect(jsonData.results[0].title.toLowerCase()).to.include(\"avengers\");\r",
              "  });"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/search/movie?api_key={{api_key}}&query=avengers",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "search",
            "movie"
          ],
          "query": [
            {
              "key": "api_key",
              "value": "{{api_key}}"
            },
            {
              "key": "query",
              "value": "avengers"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Movie Detail",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Status is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Movie ID matches\", function () {\r",
              "    pm.expect(jsonData.id).to.eql(parseInt(pm.variables.get(\"movie_id\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Title field exists\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"title\");\r",
              "});\r",
              "\r",
              "pm.test(\"Vote average is a number\", function () {\r",
              "    pm.expect(jsonData.vote_average).to.be.a(\"number\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/movie/{{movie_id}}?api_key={{api_key}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "movie",
            "{{movie_id}}"
          ],
          "query": [
            {
              "key": "api_key",
              "value": "{{api_key}}"
            }
          ]
        }
      },
      "response": []
    }
